{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "language": "french",
  "permissions": {
    "allow": [
      "Bash(node test-site.mjs)",
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(npx http-server *)",
      "Bash(npx playwright install *)",
      "Read(docs/**)",
      "Read(docs-comparaison/**)",
      "Read(docs-opencode/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
